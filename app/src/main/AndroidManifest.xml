<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- File read/write permissions for communicating with OpenClaw Agent -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_LOGS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT" />

    <!-- Service management permissions -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Floating bubble overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".OpenClawApp"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.OpenClawCar"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|density">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".agenui.AGenUISurfaceActivity"
            android:screenOrientation="landscape"
            android:exported="false" />

        <!-- 后台/被杀时离屏渲染 A2UI 卡片用：透明 + 不入最近 + 无动画 -->
        <activity
            android:name=".agenui.BackgroundCardRenderActivity"
            android:theme="@style/Theme.TransparentBackground"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:screenOrientation="landscape"
            android:exported="false" />

        <!-- Foreground service for gateway + Node.js processes -->
        <service
            android:name=".service.NodeProcessService"
            android:foregroundServiceType="specialUse"
            android:exported="true" />

        <!-- Accessibility service for UI automation -->
        <service
            android:name=".service.UiAutomationService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Floating bubble service -->
        <service
            android:name=".service.FloatingBubbleService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- Auto-start on boot -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Remote control via broadcast -->
        <receiver
            android:name=".service.CommandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.caragent.START" />
                <action android:name="com.caragent.STOP" />
            </intent-filter>
        </receiver>

        <!-- UI command broadcast receiver -->
        <receiver
            android:name=".service.UiCommandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.caragent.UI_CMD" />
            </intent-filter>
        </receiver>

        <!-- Content provider for UI command results -->
        <provider
            android:name=".service.UiResultProvider"
            android:authorities="com.caragent.bootstrap.uiresult"
            android:exported="true"
            android:grantUriPermissions="true" />

    </application>

</manifest>
