<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Force light theme for car head unit - no dark mode -->
    <style name="Theme.OpenClawCar" parent="Theme.Material3.Light.NoActionBar">
        <!-- Force disable dark mode -->
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowBackground">@color/white</item>

        <!-- Primary colors - light blue accent -->
        <item name="colorPrimary">@color/light_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/light_blue_bg</item>
        <item name="colorOnPrimaryContainer">@color/light_blue</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/light_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/light_blue</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Tab text style - large enough for car touch screen -->
    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- 透明 Activity：app 在后台/被杀时用于离屏渲染 A2UI 卡片并截图。
         窗口全透明、无动画、不进入最近任务，渲染完即 finish。 -->
    <style name="Theme.TransparentBackground" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
