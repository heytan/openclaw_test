<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_scene"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="false"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_scene"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:contentDescription="@string/proactive_title" />

            <!-- Selection overlay -->
            <View
                android:id="@+id/overlay_selected"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#334A90D9"
                android:visibility="gone" />

            <!-- Check mark -->
            <ImageView
                android:id="@+id/iv_check"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:visibility="gone"
                android:contentDescription="selected" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Expandable text section -->
    <LinearLayout
        android:id="@+id/ll_text_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_scene_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</LinearLayout>
