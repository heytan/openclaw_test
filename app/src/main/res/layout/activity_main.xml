<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Top bar: debug toggle + tab labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:elevation="2dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Debug / Production toggle -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_debug"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:thumbTint="@color/light_blue"
            app:trackTint="@color/divider"
            app:trackTintMode="src_in" />

        <!-- Tab bar -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            app:tabIndicatorColor="@color/light_blue"
            app:tabIndicatorHeight="3dp"
            app:tabIndicatorFullWidth="false"
            app:tabSelectedTextColor="@color/light_blue"
            app:tabTextColor="@color/text_hint"
            app:tabTextAppearance="@style/TabTextStyle"
            app:tabRippleColor="@color/light_blue_bg"
            app:tabMode="fixed"
            app:tabGravity="fill" />

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Content area -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
